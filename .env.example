# ================================================
# Gamification Platform — пример .env
# Скопируйте в .env и заполните своими значениями
# ================================================

# --- База данных ---
DATABASE_URL=postgresql+asyncpg://gamification_user:password@postgres:5432/gamification_db

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- JWT (обязательно сменить SECRET_KEY в prod) ---
SECRET_KEY=your_super_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# --- Окружение ---
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# --- Суперюзер (создаётся автоматически при первом старте) ---
SUPERUSER_EMAIL=admin@gamequest.local
SUPERUSER_USERNAME=admin
SUPERUSER_PASSWORD=ChangeMe123!
