# ===================================
# ОБЩИЕ НАСТРОЙКИ
# ===================================
PROJECT_NAME=gamification-platform
ENVIRONMENT=development

# ===================================
# БАЗА ДАННЫХ (PostgreSQL)
# ===================================
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=gamification_db
POSTGRES_USER=gamification_user
POSTGRES_PASSWORD=change_me_in_production_secure_password_123

# Connection string для SQLAlchemy
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ===================================
# REDIS
# ===================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ===================================
# API GATEWAY
# ===================================
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
API_GATEWAY_WORKERS=4
API_GATEWAY_RELOAD=true

# CORS Settings
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
CORS_CREDENTIALS=true

# ===================================
# БЕЗОПАСНОСТЬ (JWT)
# ===================================
# Сгенерируйте: openssl rand -hex 32
SECRET_KEY=your_super_secret_key_change_me_in_production_32_chars_minimum
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ===================================
# МИКРОСЕРВИСЫ (порты)
# ===================================
AUTH_SERVICE_PORT=8001
GAMIFICATION_SERVICE_PORT=8002
INTEGRATION_SERVICE_PORT=8003
ANALYTICS_SERVICE_PORT=8004

# Внутренние URL для межсервисного взаимодействия
AUTH_SERVICE_URL=http://auth-service:8001
GAMIFICATION_SERVICE_URL=http://gamification-service:8002
INTEGRATION_SERVICE_URL=http://integration-service:8003
ANALYTICS_SERVICE_URL=http://analytics-service:8004

# ===================================
# CELERY (асинхронные задачи)
# ===================================
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ===================================
# ИНТЕГРАЦИИ - GITHUB
# ===================================
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
GITHUB_API_URL=https://api.github.com

# ===================================
# ИНТЕГРАЦИИ - JIRA
# ===================================
JIRA_CLIENT_ID=your_jira_oauth_client_id
JIRA_CLIENT_SECRET=your_jira_oauth_client_secret
JIRA_REDIRECT_URI=http://localhost:8000/api/v1/integrations/jira/callback
JIRA_API_URL=https://your-domain.atlassian.net

# ===================================
# ИНТЕГРАЦИИ - SLACK
# ===================================
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your_slack_signing_secret
SLACK_CLIENT_ID=your_slack_client_id
SLACK_CLIENT_SECRET=your_slack_client_secret
SLACK_REDIRECT_URI=http://localhost:8000/api/v1/integrations/slack/callback

# ===================================
# ЛОГИРОВАНИЕ
# ===================================
LOG_LEVEL=INFO
LOG_FORMAT=json

# ===================================
# МОНИТОРИНГ
# ===================================
SENTRY_DSN=
ENABLE_METRICS=false

# ===================================
# FRONTEND (React)
# ===================================
REACT_APP_API_URL=http://localhost:8000/api/v1
REACT_APP_WS_URL=ws://localhost:8000/ws

# ===================================
# DEVELOPMENT TOOLS
# ===================================
# Для локальной разработки
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
